{
  "name": "@repo/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*.ts"
  },
  "scripts": {
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "typecheck": "tsc --noEmit",
    "seed": "pnpm with-env tsx scripts/seed.ts",
    "seed:remote": "dotenv -e ../../.env.production.local -- tsx scripts/seed.ts",
    "with-env": "dotenv -e ../../.env --",
    "backfill:vectors": "pnpm with-env tsx scripts/backfill-vectors.ts"
  },
  "dependencies": {
    "@repo/db": "workspace:^",
    "@trpc/server": "catalog:",
    "ai": "^7.0.19",
    "better-auth": "catalog:",
    "superjson": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@kyh/tsconfig": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "typescript": "catalog:"
  }
}
