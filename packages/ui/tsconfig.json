{
  "extends": "@kyh/tsconfig/internal-package.json",
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "lib": ["ES2022", "dom", "dom.iterable"],
    "jsx": "preserve",
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules"]
}
