{
  "extends": "@kyh/tsconfig/internal-package.json",
  "compilerOptions": {
    "lib": ["ES2023", "DOM"],
    // Internal imports use explicit .ts specifiers so consumers that alias
    // this package to source (apps/web tsconfig paths + Turbopack) resolve
    // them; tsc rewrites them to .js in the emitted dist.
    "rewriteRelativeImportExtensions": true
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist", "src/**/*.test.ts", "src/**/*.spec.ts"]
}
