{
  "name": "@loremllm/transport",
  "version": "0.7.0",
  "keywords": [
    "agent",
    "ai",
    "ai-sdk",
    "chat",
    "chatbot",
    "demo",
    "eve",
    "llm",
    "mock",
    "static-chat",
    "streaming",
    "testing",
    "transport",
    "ui-message",
    "vercel-ai-sdk"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./copy-messages-to-clipboard": {
      "types": "./dist/copy-messages-to-clipboard.d.ts",
      "import": "./dist/copy-messages-to-clipboard.js"
    },
    "./eve": {
      "types": "./dist/eve.d.ts",
      "import": "./dist/eve.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc --emitDeclarationOnly false",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "dev": "tsc --emitDeclarationOnly false --watch --preserveWatchOutput",
    "test": "vitest run",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false"
  },
  "devDependencies": {
    "@ai-sdk/react": "^4.0.20",
    "@kyh/tsconfig": "catalog:",
    "ai": "^7.0.19",
    "eve": "^0.22.3",
    "typescript": "catalog:",
    "vitest": "^4.1.10"
  },
  "peerDependencies": {
    "ai": "^6.0.0 || ^7.0.0"
  }
}
