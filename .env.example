# Local Turso server started by `pnpm -F db db` (turso dev --db-file local.db).
# TURSO_AUTH_TOKEN is only needed against a hosted Turso database — leave it
# commented out locally, since drizzle-kit rejects an empty-string token.
TURSO_DATABASE_URL="http://127.0.0.1:8080"
# TURSO_AUTH_TOKEN=""

# Embeds text through the Vercel AI Gateway. Needed to create or update an
# interaction (its input is embedded on write) AND to run any semantic query —
# interaction.query embeds the query text too, so /api/chat type:"chat" and the
# /api/eve flow 500 without it. Without a key: sign-in, browse, delete, output-only
# edits, and the lorem/markdown chat types still work.
AI_GATEWAY_API_KEY=""

# Any random string locally: `openssl rand -base64 32`
BETTER_AUTH_SECRET=""

# GitHub sign-in. Leave empty to disable the "Continue with Github" button;
# email/password still works.
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Uncomment to exercise GitHub sign-in offline against the local `emulate`
# OAuth server (`pnpm emulate`, fixtures in emulate.config.yaml). See AGENTS.md.
# NEXT_PUBLIC_GITHUB_EMULATOR_URL="http://localhost:4000"
