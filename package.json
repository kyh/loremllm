{
  "name": "loremllm",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "clean": "git clean -xdf node_modules",
    "clean:workspaces": "turbo run clean",
    "db:push": "pnpm -F db push",
    "db:push-remote": "pnpm -F db push:remote && pnpm -F builder push:remote",
    "dev": "turbo watch db studio dev --continue",
    "dev:web": "turbo watch dev --filter=@loremllm/web --continue",
    "lint": "oxlint --report-unused-disable-directives",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "format": "oxfmt",
    "lint:fix": "oxlint --fix",
    "format:fix": "oxfmt --write"
  },
  "devDependencies": {
    "dotenv-cli": "^11.0.0",
    "oxfmt": "^0.51.0",
    "oxlint": "^1.66.0",
    "pkgroll": "^2.27.0",
    "tsx": "^4.22.3",
    "turbo": "^2.9.14",
    "typescript": "catalog:"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@tailwindcss/oxide",
      "esbuild",
      "sharp"
    ]
  },
  "engines": {
    "node": ">=24"
  }
}
